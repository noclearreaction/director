#!/bin/sh
# .devcontainer/post-start — runs on every container start via postStartCommand
# This script is executed (not sourced), so it runs in its own process.
set -e

# Pin the env-lgc tag to origin/main so tooling can reference the last
# known-good container-compatible commit.
git tag -f env-lgc origin/main

# Run the full tool health check; failures are visible in the terminal on start.
task devcontainer:doctor

